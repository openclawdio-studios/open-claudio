# Open-Claudio — Environment Configuration
# Copy this file to .env and fill in your values.
# cp .env.example .env

# ==========================================
# LLM / Agent
# ==========================================

# Base URL of your LLM API (LM Studio, Ollama, OpenAI-compatible endpoint)
LLM_ENDPOINT="http://100.116.250.89:1234/v1"

# Model identifier sent to the LLM API
MODEL_NAME="gpt-oss-20b"

# API key — use "not-needed" for local LLMs that don't require auth
LLM_API_KEY="not-needed"

# Maximum ReAct reasoning steps per agent turn (default: 8)
MAX_STEPS="8"

# Comma-separated SSE URLs of all MCP servers the agent should connect to
MCP_SERVER_URLS="http://mcp_domotics:8000/sse,http://mcp_fermax:8001/sse"


# ==========================================
# Domotics MCP — Z-Wave blinds/shutters
# ==========================================

# Base URL of the home automation REST API (Z-Wave JS UI, Domoticz, etc.)
PERSIANAS_API_URL="https://your-home-server.duckdns.org"

# Bearer token for the home automation API (leave empty if not required)
PERSIANAS_API_TOKEN="your_secure_token_here"


# ==========================================
# Fermax Intercom MCP
# ==========================================

# Fermax Blue app credentials (used to authenticate against Fermax cloud API)
FERMAX_USERNAME="your_fermax_email@example.com"
FERMAX_PASSWORD="your_fermax_password"


# ==========================================
# MQTT — IoT event source
# ==========================================

# Hostname of the MQTT broker (use "mosquitto" when running via docker-compose)
MQTT_HOST="mosquitto"

# MQTT broker port (default: 1883)
MQTT_PORT="1883"

# MQTT client identifier (must be unique per connected client)
MQTT_CLIENT_ID="open-claudio-agent"

# Broker credentials — leave empty if the broker allows anonymous connections
MQTT_USERNAME=""
MQTT_PASSWORD=""


# ==========================================
# Telegram Bot — event source + reply channel
# ==========================================

# Bot token obtained from @BotFather on Telegram
# Leave empty (or unset) to disable the Telegram source
TELEGRAM_BOT_TOKEN=""

# Comma-separated list of chat IDs allowed to send commands to the bot
# Get your chat_id by messaging @userinfobot
# Leave empty to allow ALL chats (not recommended for production)
TELEGRAM_ALLOWED_CHAT_IDS=""


# ==========================================
# HTTP Webhook — event source
# ==========================================

# Set to "true" to enable the FastAPI webhook server (POST /event)
HTTP_EVENT_ENABLED="false"

# Port the webhook server listens on inside the container (mapped to 8080 externally)
HTTP_EVENT_PORT="8080"

# Bearer token to protect the /event endpoint — REQUIRED if HTTP_EVENT_ENABLED=true
# The agent will refuse to start the HTTP source if this is empty.
# Clients must send: Authorization: Bearer <your_secret>
# Generate a strong token: openssl rand -hex 32
HTTP_EVENT_SECRET=""
