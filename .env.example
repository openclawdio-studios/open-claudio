# Open-Claudio Global Configuration

# ==========================================
# Agent Configuration
# ==========================================
# The endpoint where the Agent will send its LLM requests.
LLM_ENDPOINT=http://100.116.250.89:1234/v1
MODEL_NAME=gpt-oss-20b
MAX_STEPS=8

# The internal bridge URL where the agent will find the Domotics MCP server.
# You generally don't need to change this if using the default docker-compose.yml
MCP_SERVER_URL=http://mcp_domotics:8000/sse

# ==========================================
# Domotics MCP (Z-Wave / OpenClaw)
# ==========================================
# The URL of the external Domotics API (formerly used by the NodeJS skill)
PERSIANAS_API_URL=https://northr3nd.duckdns.org
# The Bearer token for the external Domotics API
PERSIANAS_API_TOKEN=your_secure_token_here
